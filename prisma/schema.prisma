// Prisma schema for MongoDB
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  displayId      String       @unique // Short ID for display
  email          String       @unique
  name           String?
  source         String?
  campaign       String?
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  score          Int?
  metadata       Json?        // dynamic field values per lead magnet
  leadMagnetId   String?      @db.ObjectId
  leadMagnet     LeadMagnet?  @relation("LeadMagnetLeads", fields: [leadMagnetId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notes          Note[]
  activities     Activity[]

  @@index([createdAt])
  @@index([name])
  @@index([status])
  @@index([source])
  @@index([leadMagnetId])
  @@map("leads")
}

model LeadMagnet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  fields      Json     // array of form field definitions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]   @relation("LeadMagnetLeads")

  @@index([createdAt])
  @@map("lead_magnets")
}

model Note {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId           String   @db.ObjectId
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content          String
  author           String   @default("You") // Default to "You" or "System"
  isPinned         Boolean  @default(false)
  pinnedAt         DateTime? // Set when note is pinned, cleared when unpinned
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  contentUpdatedAt DateTime? // Only set when content is edited, null on creation

  @@index([leadId, pinnedAt, createdAt])
  @@map("notes")
}

model Activity {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  leadId    String       @db.ObjectId
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActivityType
  performedBy String     // Who performed the action, required
  metadata  Json?        // Additional context for the activity
  createdAt DateTime     @default(now())

  @@index([leadId, createdAt])
  @@map("activities")
}

enum ActivityType {
  NOTE_ADDED
  NOTE_UPDATED
  NOTE_DELETED
  STATUS_CHANGED
  PRIORITY_CHANGED
  LEAD_CREATED
  LEAD_UPDATED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}


enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  username  String      @unique
  email     String      @unique
  password  String?
  role      UserRole    @default(SALES)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  invite    UserInvite?
  
  @@map("users")
}

model UserInvite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("user_invites")
}

enum UserRole {
  ADMIN
  MARKETING
  SUPPORT
  SALES
  HR
  DEV
}
