// Prisma schema for MongoDB
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  displayId      String       @unique // Short ID for display
  email          String       @unique
  name           String?
  source         String?
  campaign       String?
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  metadata       Json?        // dynamic field values per lead magnet
  leadMagnetId   String?      @db.ObjectId
  leadMagnet     LeadMagnet?  @relation("LeadMagnetLeads", fields: [leadMagnetId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  notes          Note[]
  activities     Activity[]

  @@index([createdAt])
  @@index([name])
  @@index([status])
  @@index([source])
  @@index([leadMagnetId])
  @@map("leads")
}

model LeadMagnet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  fields      Json     // array of form field definitions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]   @relation("LeadMagnetLeads")

  @@index([createdAt])
  @@map("lead_magnets")
}

model Note {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  leadId           String    @db.ObjectId
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content          String
  
  // User relation for author (nullified when user deleted)
  authorId         String?   @db.ObjectId
  authorUser       User?     @relation("NotesAuthored", fields: [authorId], references: [id], onDelete: SetNull)
  author           String    // Denormalized username for display
  
  // User relation for updatedBy (nullified when user deleted)
  updatedById      String?   @db.ObjectId
  updatedByUser    User?     @relation("NotesUpdated", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedBy        String?   // Denormalized username for display
  
  isPinned         Boolean   @default(false)
  pinnedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  contentUpdatedAt DateTime?

  @@index([leadId, pinnedAt, createdAt])
  @@map("notes")
}

model Activity {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  leadId          String       @db.ObjectId
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type            ActivityType
  
  // User relation for performedBy (nullified when user deleted)
  performedById   String?      @db.ObjectId
  performedByUser User?        @relation("ActivitiesPerformed", fields: [performedById], references: [id], onDelete: SetNull)
  performedBy     String?      // Denormalized username for display (null for automated events)
  
  metadata        Json?        // Additional context for the activity
  createdAt       DateTime     @default(now())

  @@index([leadId, createdAt])
  @@map("activities")
}

enum ActivityType {
  STATUS_CHANGED
  PRIORITY_CHANGED
  LEAD_CREATED
  LEAD_UPDATED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}


enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                     String      @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  username               String      @unique
  email                  String      @unique
  password               String?
  avatar                 String      @default("") // Optional avatar image URL
  role                   UserRole    @default(MEMBER)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  
  // Auth-related relations
  invite                 UserInvite?
  passwordResetToken     PasswordResetToken?
  emailVerificationToken EmailVerificationToken?
  
  // Activity tracking relations
  notesAuthored          Note[]      @relation("NotesAuthored")
  notesUpdated           Note[]      @relation("NotesUpdated")
  activitiesPerformed    Activity[]  @relation("ActivitiesPerformed")
  
  @@map("users")
}

model UserInvite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("user_invites")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  newEmail  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

enum UserRole {
  OWNER
  ADMIN
  DEV
  MEMBER
}
