# Database Configuration
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/leadmagnet?retryWrites=true&w=majority"

# Security - API Routes
# Comma-separated list of allowed origins for CORS
# Example: "https://clientname.com,https://www.clientname.com"
CLIENT_ALLOWED_ORIGIN="https://example.com,https://www.example.com"

# Optional API key for additional security
# Client websites must include this in x-api-key header
CLIENT_API_KEY="your-secret-api-key-here"

# Admin Authentication
# Password for admin panel login
ADMIN_PASSWORD="your-secure-admin-password"

# Secret for cookie encryption (generate a random string)
NEXTAUTH_SECRET="your-nextauth-secret-for-cookies"

# Email Configuration (Future Integration)
# Uncomment and configure when ready to integrate email service
# EMAIL_SERVICE_API_KEY=""
# EMAIL_FROM_ADDRESS="leads@yourdomain.com"

# Lead Magnet PDF URL (optional)
# URL where your lead magnet PDF is hosted
# LEAD_MAGNET_PDF_URL="https://yourdomain.com/lead-magnet.pdf"

# Environment
NODE_ENV="development"
